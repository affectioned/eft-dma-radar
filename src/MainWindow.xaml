<hc:Window x:Class="eft_dma_radar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        xmlns:local="clr-namespace:eft_dma_radar.UI.Pages"
           mc:Ignorable="d"
        Title="EFT DMA Radar"
        ShowTitle="False"
        WindowStartupLocation="CenterScreen"
        Height="720" 
        Width="1280"
        NonClientAreaHeight="32">

    <hc:Window.NonClientAreaContent>
        <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Image Source="{StaticResource AppIconImage}" Width="24" Height="24" Margin="10,0,0,0"/>
            <TextBlock x:Name="TitleTextBlock" Grid.Column="1" Text="EFT DMA Radar" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>
    </hc:Window.NonClientAreaContent>

    <Grid>
        <Grid Name="mainContentGrid" Margin="0,0,0,0">
            <skia:SKGLElement x:Name="skCanvas"/>
        </Grid>

        <Canvas Name="ToolbarCanvas" Panel.ZIndex="1500">
            <Border x:Name="customToolbar"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            Canvas.Left="900" Canvas.Top="5"
            Padding="5,2" CornerRadius="4"
            Height="54">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.3" BlurRadius="5"/>
                </Border.Effect>

                <hc:SimpleStackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="10" Height="44" Cursor="SizeAll" VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="Transparent"/>
                        </Border.Background>
                        <hc:SimpleStackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,2"/>
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,2"/>
                            <Ellipse Width="4" Height="4" Fill="{DynamicResource BorderBrush}" Margin="0,2,0,2"/>
                        </hc:SimpleStackPanel>
                    </Border>

                    <!-- Debug button (hidden) -->
                    <Button x:Name="btnDebug" Visibility="Collapsed"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Debug/test functionality button"
                            Width="42" Height="48" Padding="4,2"
                            Click="btnDebug_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource StarGeometry}" Width="18" Height="16" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Debug" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnFreeMode"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Toggle Follow/Free Mode"
                            Width="42" Height="48" Padding="4,2"
                            Click="btnFreeMode_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource MapPinGeometry}" Width="14" Height="16" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Map" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnLootSettings"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Opens the loot settings"
                            Width="42" Height="48" Padding="4,2"
                            Click="btnLootSettings_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource DollarSignGeometry}" Width="14" Height="16" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Loot" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnLootFilter"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Opens the loot filter panel"
                            Width="42" Height="48" Padding="4,2"
                            Click="btnLootFilter_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource FilterGeometry}" Width="16" Height="16" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Filter" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnESPSettings"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Opens the ESP configuration panel"
                            Width="42" Height="48" Padding="4,2"
                            Click="btnESPSettings_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource GlassesGeometry}" Width="20" Height="13" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="ESP" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnAimbot"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Opens the aimbot configuration panel"
                            Width="42" Height="48" Padding="4,2"
                            Click="btnAimbot_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource CrosshairsGeometry}" Width="16" Height="16" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Aimbot" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnWatchlist"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Opens the watchlist panel"
                            Width="42" Height="48" Padding="4,2"
                            Click="btnWatchlist_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource UsersGeometry}" Width="18" Height="14" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Watch" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnPlayerHistory"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Opens the player history panel"
                            Width="42" Height="48" Padding="4,2"
                            Click="btnPlayerHistory_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource ClockRotatedGeometry}" Width="16" Height="16" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="History" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnGeneralSettings"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Opens the general settings panel"
                            Width="48" Height="48" Padding="4,2"
                            Click="btnGeneralSettings_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource GearGeometry}" Width="16" Height="16" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Settings" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnSearchSettings"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Search settings (Ctrl+F)"
                            Width="46" Height="48" Padding="4,2"
                            Click="btnSettingsSearch_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource SearchGeometry}" Width="16" Height="16" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Search" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="36" Fill="{DynamicResource BorderBrush}" Opacity="0.7" Margin="3,0"/>

                    <Button x:Name="btnRestart"
                            Style="{StaticResource ToolbarLabelButtonStyle}"
                            ToolTip="Restarts the Radar for the current raid instance"
                            Width="46" Height="48" Padding="4,2"
                            Click="btnRestart_Click">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="{StaticResource ArrowsRotateGeometry}" Width="16" Height="16" Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Restart" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                </hc:SimpleStackPanel>
            </Border>
        </Canvas>

        <!-- general settings panel -->
        <Canvas Name="GeneralSettingsCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="GeneralSettingsPanel" 
                    Width="340" Height="600"
                    Canvas.Left="700" Canvas.Top="50"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:GeneralSettingsControl x:Name="GeneralSettingsControl"/>
            </Border>
        </Canvas>
        <!-- watchlist panel -->
        <Canvas Name="WatchlistCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="WatchlistPanel"
                    Width="350" Height="450"
                    Canvas.Left="550" Canvas.Top="110"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:WatchlistControl x:Name="WatchlistControl"/>
            </Border>
        </Canvas>

        <!-- player history panel -->
        <Canvas Name="PlayerHistoryCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="PlayerHistoryPanel"
                    Width="490" Height="200"
                    Canvas.Left="550" Canvas.Top="110"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:PlayerHistoryControl x:Name="PlayerHistoryControl"/>
            </Border>
        </Canvas>
         <!-- loot settings panel -->
        <Canvas Name="LootSettingsCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="LootSettingsPanel" 
                    Width="350" Height="450"
                    Canvas.Left="700" Canvas.Top="50"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:LootSettingsControl x:Name="LootSettingsControl"/>
            </Border>
        </Canvas>

        <!-- esp panel -->
        <Canvas Name="ESPCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="ESPPanel" 
                    Width="350" Height="550"
                    Canvas.Left="600" Canvas.Top="90"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:ESPControl x:Name="ESPControl"/>
            </Border>
        </Canvas>

        <!-- loot filter panel -->
        <Canvas Name="LootFilterCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="LootFilterPanel" 
                    Width="350" Height="450"
                    Canvas.Left="550" Canvas.Top="110"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:LootFilterControl x:Name="LootFilterControl"/>
            </Border>
        </Canvas>
        
        <!-- settings search panel -->
        <Canvas Name="SettingsSearchCanvas" Panel.ZIndex="1000">
          <Canvas.Resources>
            <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
          </Canvas.Resources>

          <Border x:Name="SettingsSearchPanel"
                  Width="420" Height="560"
                  Canvas.Left="760" Canvas.Top="60"
                  CornerRadius="8"
                  Visibility="Collapsed"
                  Effect="{StaticResource PanelShadow}"
                  Background="Transparent"
                  BorderThickness="0">
            <local:SettingsSearchControl x:Name="SettingsSearchControl"/>
          </Border>
        </Canvas>       
        <!-- aimbot panel -->
        <Canvas Name="AimbotCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="AimbotPanel"
                    Width="340" Height="420"
                    Canvas.Left="600" Canvas.Top="80"
                    CornerRadius="8"
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:AimbotControl x:Name="AimbotControl"/>
            </Border>
        </Canvas>

        <!-- map setup panel -->
        <Canvas Name="MapSetupCanvas" Panel.ZIndex="1000">
            <Canvas.Resources>
                <DropShadowEffect x:Key="PanelShadow" BlurRadius="15" ShadowDepth="5" Direction="315" Color="Black" Opacity="0.5"/>
            </Canvas.Resources>

            <Border x:Name="MapSetupPanel" 
                    Width="365" Height="145"
                    Canvas.Left="550" Canvas.Top="110"
                    CornerRadius="8" 
                    Visibility="Collapsed"
                    Effect="{StaticResource PanelShadow}"
                    Background="Transparent"
                    BorderThickness="0">
                <local:MapSetupControl x:Name="MapSetupControl"/>
            </Border>
        </Canvas>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Width="360"
                      Margin="0,0,20,20">
            <hc:SimpleStackPanel x:Name="GrowlPanel"
                        hc:Growl.Token="MainGrowl"
                        Orientation="Vertical"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"/>
        </ScrollViewer>
    </Grid>
</hc:Window>