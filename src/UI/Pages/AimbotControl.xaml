<UserControl x:Class="eft_dma_radar.UI.Pages.AimbotControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350"
             MinWidth="200" MinHeight="200">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header - Draggable area -->
        <Border x:Name="DragHandle" Grid.Row="0" Style="{StaticResource PanelHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Aimbot" Style="{StaticResource PanelHeaderText}"/>
                <Border Grid.Column="1" Style="{StaticResource CloseButtonBorder}">
                    <Button x:Name="btnCloseHeader" Style="{StaticResource CloseButton}"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border Background="{DynamicResource RegionBrush}"
                    CornerRadius="0,0,8,8"/>

            <hc:TabControl Style="{StaticResource TabControlInLine}"
                           HorizontalContentAlignment="Left"
                           Background="Transparent"
                           BorderThickness="0">

                <hc:TabItem Header="Settings">
                    <ScrollViewer Style="{StaticResource PanelScrollViewer}">
                        <hc:SimpleStackPanel>

                            <!-- Master toggle -->
                            <CheckBox x:Name="chkEnabled" Content="Enable Aimbot"
                                      Style="{StaticResource DynamicCheckBoxStyle}"
                                      Margin="8,8,8,4"
                                      Checked="chkEnabled_Changed" Unchecked="chkEnabled_Changed"/>

                            <!-- Device -->
                            <Expander x:Name="expDevice" Header="Makcu Device" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="COM Port" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                        <hc:TextBox x:Name="txtMakcuPort" Grid.Column="1"
                                                    hc:InfoElement.Placeholder="e.g. COM3"
                                                    TextChanged="txtMakcuPort_TextChanged"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="btnConnect" Content="Connect"
                                                Grid.Column="0"
                                                Style="{StaticResource ButtonPrimary}"
                                                Click="btnConnect_Click"/>
                                        <TextBlock x:Name="txtStatus"
                                                   Grid.Column="2"
                                                   Text="Disconnected" Foreground="Red"
                                                   Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                    </Grid>

                                    <CheckBox x:Name="chkAutoConnect" Content="Auto-connect on startup"
                                              Style="{StaticResource DynamicCheckBoxStyle}"
                                              Margin="0,0,0,8"
                                              Checked="chkAutoConnect_Changed" Unchecked="chkAutoConnect_Changed"/>

                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- Targeting -->
                            <Expander x:Name="expTargeting" Header="Targeting" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Aim Bone" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="cboAimBone" Grid.Column="1"
                                                  SelectionChanged="cboAimBone_SelectionChanged"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="FOV (degrees)" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                        <hc:NumericUpDown x:Name="nudFov" Grid.Column="1"
                                                          Value="10" Minimum="1" Maximum="180"
                                                          DecimalPlaces="1" Increment="0.5"
                                                          ValueChanged="Setting_Changed"/>
                                    </Grid>

                                    <CheckBox x:Name="chkAimAI" Content="Target AI enemies"
                                              Style="{StaticResource DynamicCheckBoxStyle}"
                                              Margin="0,0,0,8"
                                              Checked="chkAimAI_Changed" Unchecked="chkAimAI_Changed"/>

                                    <CheckBox x:Name="chkShowFovCircle" Content="Show FOV circle on fuser"
                                              Style="{StaticResource DynamicCheckBoxStyle}"
                                              Margin="0,0,0,8"
                                              Checked="chkShowFovCircle_Changed" Unchecked="chkShowFovCircle_Changed"/>

                                </hc:SimpleStackPanel>
                            </Expander>

                            <!-- Mouse Movement -->
                            <Expander x:Name="expMouse" Header="Mouse Movement" Style="{StaticResource PanelExpander}" IsExpanded="True">
                                <hc:SimpleStackPanel Style="{StaticResource ExpanderContent}" Margin="2,8,2,0">

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Smooth X" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                        <hc:NumericUpDown x:Name="nudAlphaX" Grid.Column="1"
                                                          Value="0.1" Minimum="0.01" Maximum="1"
                                                          DecimalPlaces="2" Increment="0.01"
                                                          ValueChanged="Setting_Changed"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Smooth Y" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                        <hc:NumericUpDown x:Name="nudAlphaY" Grid.Column="1"
                                                          Value="0.1" Minimum="0.01" Maximum="1"
                                                          DecimalPlaces="2" Increment="0.01"
                                                          ValueChanged="Setting_Changed"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Deadzone (px)" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                        <hc:NumericUpDown x:Name="nudDeadzone" Grid.Column="1"
                                                          Value="3" Minimum="0" Maximum="20"
                                                          DecimalPlaces="1" Increment="0.5"
                                                          ValueChanged="Setting_Changed"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Gaussian Noise" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                        <hc:NumericUpDown x:Name="nudGaussianNoise" Grid.Column="1"
                                                          Value="0" Minimum="0" Maximum="2"
                                                          DecimalPlaces="2" Increment="0.05"
                                                          ValueChanged="Setting_Changed"/>
                                    </Grid>

                                </hc:SimpleStackPanel>
                            </Expander>

                        </hc:SimpleStackPanel>
                    </ScrollViewer>
                </hc:TabItem>

            </hc:TabControl>

            <!-- Resize handle -->
            <Grid Style="{StaticResource ResizeHandle}"
                  MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown">
                <Path Style="{StaticResource ResizeHandleIcon}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
